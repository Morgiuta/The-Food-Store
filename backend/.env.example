POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=catalogo_productos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generar_una_clave_larga_aleatoria_de_32_bytes_o_mas
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# MercadoPago (Checkout Pro)
# Credenciales de prueba: https://www.mercadopago.com.ar/developers/panel/app
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000
# URL publica del webhook IPN (usar ngrok u otro tunel en desarrollo)
MP_NOTIFICATION_URL=https://tu-dominio-ngrok.com/api/v1/pagos/webhook
# Clave secreta del webhook (Panel MP > Webhooks > Firma secreta)
MP_WEBHOOK_SECRET=tu_firma_secreta_del_webhook

# Cloudinary
CLOUDINARY_CLOUD_NAME=mi-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmn

# URL base del frontend para las back_urls de Checkout Pro
FRONTEND_URL=http://localhost:5173
